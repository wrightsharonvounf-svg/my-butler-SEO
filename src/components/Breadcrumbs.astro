---
const { title } = Astro.props;
---

<nav>
  <a href="/">Главная</a> →
  <a href="/blog/">Блог</a> →
  <span>{title}</span>
</nav>

<script type="application/ld+json">
{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Главная",
      "item": "https://www.butler-tim.ru/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Блог",
      "item": "https://www.butler-tim.ru/blog/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title
    }
  ]
})}
</script>
